# Copie para .env e preencha. NÃO comite o .env (já está no .gitignore).

# --- Supabase (obrigatório) ---
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key

# --- Marca / white-label (opcional) ---
# Nome exibido no app e no título da aba
VITE_APP_NAME=Controle de Ponto
# "Handle" opcional mostrado ao lado do nome (ex.: sistema.suaempresa). Deixe vazio para ocultar.
VITE_APP_HANDLE=
# Sigla do ícone/selo (2-3 letras). Se vazio, usa as iniciais do VITE_APP_NAME.
VITE_APP_BADGE=
